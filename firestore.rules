rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users collection
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Allow creation on registration
      allow update: if isSignedIn() && (
        request.auth.uid == uid || 
        hasRole('admin') ||
        (hasRole('teacher') && resource.data.role == 'student' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrolledCourseIds']))
      );
    }

    // Courses collection
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create: if hasRole('admin') || hasRole('teacher');
      allow update: if hasRole('admin') || (hasRole('teacher') && resource.data.teacherId == request.auth.uid);
      allow delete: if hasRole('admin');
    }

    // Attendance collection
    match /attendance/{recordId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('teacher');
    }

    // Settings collection
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin');
    }

    // Audit logs
    match /auditLogs/{logId} {
      allow read: if hasRole('admin');
      allow create: if isSignedIn();
    }
  }
}
